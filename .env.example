# Backend
FLASHCUTTER_APP_NAME=flashcutter
FLASHCUTTER_ENVIRONMENT=development
FLASHCUTTER_DATABASE_URL=sqlite:///./flashcutter.dev.db
FLASHCUTTER_STORAGE_ROOT=storage
FLASHCUTTER_DEFAULT_TEMPLATE_NAME=simple_concat

# Path to a TTF/OTF/TTC font with CJK glyphs (used for drawtext / hook & CTA cards).
# Leave unset to auto-detect; the backend tries PingFang/STHeiti/Noto CJK in order.
# FLASHCUTTER_FONT_PATH=/System/Library/Fonts/PingFang.ttc

# Frontend
VITE_API_BASE_URL=
