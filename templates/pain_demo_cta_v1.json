{
  "template_id": "pain_demo_cta_v1",
  "name": "痛点-演示-CTA广告模板",
  "duration_range": [15, 25],
  "slots": [
    {
      "slot": "hook",
      "role_required": ["hook", "problem"],
      "duration": [1.5, 3.0],
      "rules": {
        "motion_level": ["medium", "high"],
        "face_visible": true
      }
    },
    {
      "slot": "problem",
      "role_required": ["problem"],
      "duration": [2.0, 5.0]
    },
    {
      "slot": "demo",
      "role_required": ["product_demo"],
      "duration": [6.0, 12.0]
    },
    {
      "slot": "proof",
      "role_required": ["proof", "reaction", "product_closeup"],
      "duration": [2.0, 5.0],
      "optional": true
    },
    {
      "slot": "cta",
      "role_required": ["cta"],
      "duration": [2.0, 4.0]
    }
  ],
  "subtitle_templates": [
    "这个问题你是不是也遇到过？",
    "用了之后才发现，原来可以这么简单",
    "现在下单，限时优惠"
  ],
  "music_pool": ["soft_lifestyle_01.mp3", "fast_ugc_02.mp3"],
  "visual_style": {
    "crop": ["9:16", "1:1"],
    "color_preset": ["natural_warm", "clean_bright"],
    "subtitle_style": ["ugc_bold", "clean_bottom"]
  },
  "replacement_elements": ["cat1", "dog1"]
}
