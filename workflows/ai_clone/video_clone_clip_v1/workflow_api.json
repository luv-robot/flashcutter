{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ltx-video-2b-v0.9.5.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "t5xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "ltxv",
      "device": "default"
    }
  },
  "3": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "flashcutter/placeholder.png"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "A clean short video clip with natural product-ad motion, realistic lighting, smooth camera movement, reusable social media advertising footage."
    }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "low quality, distorted, deformed, flicker, artifacts, text, watermark"
    }
  },
  "6": {
    "class_type": "LTXVImgToVideo",
    "inputs": {
      "positive": ["4", 0],
      "negative": ["5", 0],
      "vae": ["1", 2],
      "image": ["3", 0],
      "width": 512,
      "height": 320,
      "length": 17,
      "batch_size": 1,
      "strength": 0.75
    }
  },
  "7": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "steps": 8,
      "max_shift": 2.05,
      "base_shift": 0.95,
      "stretch": true,
      "terminal": 0.1,
      "latent": ["6", 2]
    }
  },
  "8": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "9": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["1", 0],
      "add_noise": true,
      "noise_seed": 12345,
      "cfg": 3.0,
      "positive": ["6", 0],
      "negative": ["6", 1],
      "sampler": ["8", 0],
      "sigmas": ["7", 0],
      "latent_image": ["6", 2]
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae": ["1", 2]
    }
  },
  "11": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["10", 0],
      "frame_rate": 12,
      "loop_count": 0,
      "filename_prefix": "flashcutter_ltx_clone",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 23,
      "save_metadata": true,
      "trim_to_audio": false,
      "pingpong": false,
      "save_output": true
    }
  }
